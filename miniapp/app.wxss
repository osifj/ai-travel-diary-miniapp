/* ==========================================
   AI 游玩日志生成系统 — 全局样式
   ========================================== */

/* 颜色变量 (注释形式 — 小程序不支持 CSS 变量) */
/* 主色: #4A90D9, 辅助: #5CB85C, 警告: #F0AD4E, 危险: #D9534F */

page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 16px;
  color: #333;
  background-color: #f5f5f5;
}

/* 通用容器 */
.container {
  padding: 20px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

/* 按钮 */
.btn-primary {
  background-color: #4A90D9;
  color: #fff;
  border-radius: 8px;
  padding: 14px 32px;
  font-size: 16px;
  border: none;
}

.btn-primary:active {
  background-color: #3A7BC8;
}

.btn-secondary {
  background-color: #fff;
  color: #4A90D9;
  border: 2px solid #4A90D9;
  border-radius: 8px;
  padding: 12px 28px;
  font-size: 16px;
}

.btn-block {
  display: block;
  width: 100%;
}

/* 文本 */
.title {
  font-size: 22px;
  font-weight: 700;
  color: #222;
  margin-bottom: 8px;
}

.subtitle {
  font-size: 14px;
  color: #999;
  margin-bottom: 20px;
}

.tag {
  display: inline-block;
  background: #e8f4fd;
  color: #4A90D9;
  padding: 4px 12px;
  border-radius: 16px;
  font-size: 12px;
  margin: 4px;
}

/* Loading */
.loading-spinner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 0;
}

/* 步骤指示器 */
.steps {
  padding: 0;
}

.step {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.step:last-child {
  border-bottom: none;
}

.step-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  font-size: 14px;
  flex-shrink: 0;
}

.step-icon.pending {
  background: #f0f0f0;
  color: #bbb;
}

.step-icon.active {
  background: #e8f4fd;
  color: #4A90D9;
}

.step-icon.done {
  background: #d4edda;
  color: #28a745;
}

.step-text {
  flex: 1;
  font-size: 14px;
  color: #666;
}

.step-text.active {
  color: #4A90D9;
  font-weight: 600;
}

.step-text.done {
  color: #28a745;
}
