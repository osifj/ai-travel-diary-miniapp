<!-- pages/upload/upload.wxml — 照片上传页 -->
<view class="container">
  <!-- 说明 -->
  <view class="card">
    <text class="section-title">📷 选择旅行照片</text>
    <text class="section-desc">从手机相册选择旅行中拍摄的照片，支持 JPG / PNG 格式。\n建议选择包含 GPS 位置信息的原图。</text>
  </view>

  <!-- 已选照片预览 -->
  <view wx:if="{{selectedImages.length > 0}}" class="preview-section">
    <text class="section-label">已选择 {{selectedImages.length}} 张照片</text>
    <view class="preview-grid">
      <view wx:for="{{selectedImages}}" wx:key="index" class="preview-item">
        <image src="{{item.path}}" mode="aspectFill" class="preview-img" />
        <view class="preview-remove" data-index="{{index}}" bindtap="removeImage">✕</view>
        <text wx:if="{{item.size}}" class="preview-size">{{item.size > 1024*1024 ? (item.size/1024/1024).toFixed(1) + 'MB' : (item.size/1024).toFixed(0) + 'KB'}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn-secondary btn-block" bindtap="chooseImages" disabled="{{isUploading}}">
      {{selectedImages.length > 0 ? '继续添加照片' : '从相册选择照片'}}
    </button>

    <button
      wx:if="{{selectedImages.length > 0 && !isUploading}}"
      class="btn-primary btn-block"
      bindtap="uploadAll"
    >
      上传 {{selectedImages.length}} 张照片
    </button>
  </view>

  <!-- 上传进度 -->
  <view wx:if="{{isUploading}}" class="card upload-progress">
    <text class="progress-title">上传中...</text>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{uploadProgress}}%"></view>
    </view>
    <text class="progress-text">{{doneCount}} / {{totalCount}} ({{uploadProgress}}%)</text>
  </view>

  <!-- 上传结果 -->
  <view wx:if="{{uploadResults.length > 0 && !isUploading}}" class="card">
    <text class="section-label">上传结果</text>
    <view wx:for="{{uploadResults}}" wx:key="index" class="result-item">
      <text class="result-icon">{{item.success ? '✅' : '❌'}}</text>
      <view class="result-info">
        <text class="result-name">{{item.filename || '未知文件'}}</text>
        <text wx:if="{{item.exif}}" class="result-exif">{{item.exif.taken_time || '无时间'}} | {{item.exif.location_status === 'found' ? '有GPS' : '无GPS'}}</text>
        <text wx:if="{{item.error}}" class="result-error">{{item.error}}</text>
      </view>
    </view>
  </view>

  <!-- 下一步 -->
  <button
    wx:if="{{canAnalyze}}"
    class="btn-primary btn-block"
    bindtap="goToAnalyze"
  >
    开始 AI 分析 →
  </button>

  <!-- 空状态 -->
  <view wx:if="{{selectedImages.length === 0 && uploadResults.length === 0}}" class="empty-state">
    <text class="empty-icon">📷</text>
    <text class="empty-text">点击上方按钮选择旅行照片</text>
  </view>
</view>
