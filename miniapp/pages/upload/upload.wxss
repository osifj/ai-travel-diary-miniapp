/* pages/upload/upload.wxss */

.section-title {
  font-size: 16px;
  font-weight: 600;
  display: block;
  margin-bottom: 6px;
}

.section-desc {
  font-size: 12px;
  color: #999;
  display: block;
  line-height: 1.6;
}

.preview-section {
  margin-bottom: 16px;
}

.section-label {
  font-size: 14px;
  color: #666;
  display: block;
  margin-bottom: 10px;
}

.preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.preview-item {
  width: calc(33.33% - 6px);
  position: relative;
  border-radius: 8px;
  overflow: hidden;
  background: #eee;
}

.preview-img {
  width: 100%;
  height: 100px;
  display: block;
}

.preview-remove {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 22px;
  height: 22px;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}

.preview-size {
  position: absolute;
  bottom: 2px;
  left: 4px;
  font-size: 10px;
  color: #fff;
  background: rgba(0,0,0,0.5);
  padding: 1px 4px;
  border-radius: 4px;
}

.action-buttons {
  margin-bottom: 16px;
}

.action-buttons button {
  margin-bottom: 10px;
}

.upload-progress {
  margin-bottom: 16px;
}

.progress-title {
  font-size: 14px;
  color: #4A90D9;
  font-weight: 600;
  display: block;
  margin-bottom: 10px;
}

.progress-bar {
  height: 8px;
  background: #e8f4fd;
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 6px;
}

.progress-fill {
  height: 100%;
  background: #4A90D9;
  border-radius: 4px;
  transition: width 0.3s;
}

.progress-text {
  font-size: 12px;
  color: #999;
}

.result-item {
  display: flex;
  align-items: flex-start;
  padding: 8px 0;
  border-bottom: 1px solid #f5f5f5;
}

.result-item:last-child {
  border-bottom: none;
}

.result-icon {
  font-size: 18px;
  margin-right: 10px;
  margin-top: 2px;
}

.result-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.result-name {
  font-size: 13px;
  color: #333;
}

.result-exif {
  font-size: 11px;
  color: #999;
  margin-top: 2px;
}

.result-error {
  font-size: 11px;
  color: #dc3545;
  margin-top: 2px;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 14px;
  color: #bbb;
}
