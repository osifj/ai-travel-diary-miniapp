<!-- pages/analyzing/analyzing.wxml — 分析进度页 -->
<view class="container">
  <!-- 正常进度 -->
  <view wx:if="{{showNormalArea}}" class="analyzing-area">
    <view class="spinner-area">
      <view wx:if="{{showSpinner}}" class="spinner"></view>
      <view wx:else class="done-icon">✅</view>
    </view>

    <text class="analyzing-title">
      {{analyzingTitle}}
    </text>

    <!-- 步骤指示器 -->
    <view class="steps">
      <view wx:for="{{steps}}" class="step">
        <view class="step-icon {{item.status}}">
          <text wx:if="{{item.isDone}}">✓</text>
          <text wx:elif="{{item.isActive}}">●</text>
          <text wx:else>○</text>
        </view>
        <view class="step-info">
          <text class="step-title {{item.status}}">{{item.title}}</text>
          <text class="step-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 错误状态 -->
  <view wx:else class="error-area">
    <text class="error-icon">⚠️</text>
    <text class="error-title">分析失败</text>
    <text class="error-message">{{errorMessage}}</text>
    <button class="btn-primary" bindtap="retry">重试</button>
    <button class="btn-secondary" bindtap="goBack">返回</button>
  </view>
</view>
