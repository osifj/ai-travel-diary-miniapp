/* pages/analyzing/analyzing.wxss */

.analyzing-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40px;
}

.spinner-area {
  margin-bottom: 24px;
}

.spinner {
  width: 48px;
  height: 48px;
  border: 4px solid #e8f4fd;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.done-icon {
  font-size: 64px;
}

.analyzing-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 32px;
}

.steps {
  width: 100%;
  max-width: 320px;
}

.step {
  display: flex;
  align-items: flex-start;
  padding: 14px 0;
}

.step-icon {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  font-size: 13px;
  flex-shrink: 0;
  margin-top: 2px;
}

.step-icon.pending {
  background: #f0f0f0;
  color: #bbb;
}

.step-icon.active {
  background: #4A90D9;
  color: #fff;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.step-icon.done {
  background: #d4edda;
  color: #28a745;
}

.step-info {
  display: flex;
  flex-direction: column;
}

.step-title {
  font-size: 15px;
  font-weight: 500;
  color: #666;
}

.step-title.active {
  color: #4A90D9;
  font-weight: 600;
}

.step-title.done {
  color: #28a745;
}

.step-desc {
  font-size: 12px;
  color: #bbb;
  margin-top: 2px;
}

/* 错误 */
.error-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60px;
}

.error-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.error-title {
  font-size: 18px;
  font-weight: 600;
  color: #dc3545;
  margin-bottom: 8px;
}

.error-message {
  font-size: 14px;
  color: #999;
  text-align: center;
  margin-bottom: 24px;
  max-width: 280px;
}

.error-area button {
  width: 200px;
  margin-bottom: 10px;
}
