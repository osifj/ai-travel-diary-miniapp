/* pages/map/map.wxss */

.map-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 300px;
  background: #f8f8f8;
  border-radius: 12px;
  margin: 20px 0;
}

.map-icon {
  font-size: 64px;
  margin-bottom: 12px;
}

.map-text {
  font-size: 16px;
  color: #999;
  margin-bottom: 4px;
}

.map-hint {
  font-size: 12px;
  color: #ccc;
}
