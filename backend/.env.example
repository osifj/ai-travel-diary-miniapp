# ==========================================
# AI 游玩日志生成系统 — 环境配置
# ==========================================
# 复制此文件为 .env 并填入真实值:
#   cp .env.example .env
# ==========================================

# --- 小米 MiMo API 配置 ---
# MiMo 多模态模型 API Key
MIMO_API_KEY=your_api_key_here
# MiMo API Base URL (OpenAI-compatible endpoint)
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# MiMo 图片理解模型名称
MIMO_MODEL=mimo-v2.5
# 高阶图片识别配置: 高质量 JSON 输出，避免真机等待超时
MIMO_MAX_COMPLETION_TOKENS=4096
MIMO_TEMPERATURE=0.1
MIMO_TOP_P=0.9
MIMO_RESPONSE_FORMAT=json_object
MIMO_THINKING_TYPE=disabled
MIMO_TIMEOUT_SECONDS=120

# --- DeepSeek 文本生成配置 ---
# 用于 MiMo 失败兜底描述、丰富游玩日记生成
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_COMPLETION_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.8
DEEPSEEK_TIMEOUT_SECONDS=90
DEEPSEEK_THINKING_TYPE=disabled

# --- 天气查询 ---
# 默认使用 Open-Meteo 公开接口，无需 API Key

# --- 服务器配置 ---
HOST=0.0.0.0
PORT=8000

# --- 地点解析 API (可选) ---
# 第一版使用 mock geocoder，后续可接入:
# 腾讯位置服务: https://lbs.qq.com/
# 高德地图: https://lbs.amap.com/
# 百度地图: https://lbsyun.baidu.com/
# OpenStreetMap Nominatim (免费): https://nominatim.org/
GEOCODER_PROVIDER=nominatim
# nominatim 免费，无需 API Key；也可换 tencent/amap/baidu
GEOCODER_API_KEY=
